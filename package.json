{
  "name": "border-sync-pro",
  "version": "1.0.0",
  "description": "Professional LRC lyrics synchronization desktop app",
  "main": "src/main/index.js",
  "homepage": "https://github.com/AdeMasel/border-sync-pro",
  "author": "AdeMasel",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "vite src/renderer & wait-on http://localhost:5173 && electron .",
    "build": "vite build src/renderer",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-log": "^5.1.2",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ademasel.borderSyncPro",
    "productName": "Border Sync Pro",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.music",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
